    "cf:preview": "pnpm run build && wrangler dev"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.35.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "latest",
